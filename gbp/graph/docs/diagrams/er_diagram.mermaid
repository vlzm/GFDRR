```mermaid
---
title: Entity Relationships
---

erDiagram
    NODES {
        string id PK
        string node_type
    }
    
    RESOURCES {
        string id PK
        string resource_type
    }
    
    COMMODITIES {
        string id PK
        string commodity_type
    }
    
    COORDINATES {
        string node_id FK
        float latitude
        float longitude
    }
    
    NODE_ATTRIBUTE {
        string node_id FK
        string granularity_key_1 "optional"
        string granularity_key_N "optional"
        float value
    }
    
    EDGE_ATTRIBUTE {
        string source_id FK
        string target_id FK
        string granularity_key_1 "optional"
        string granularity_key_N "optional"
        float value
    }
    
    FLOWS {
        string source_id FK
        string target_id FK
        string period
        string commodity_id FK "optional"
        float value
    }
    
    DEMANDS {
        string node_id FK
        string commodity_id FK
        string period
        float quantity
    }
    
    INVENTORY {
        string node_id FK
        string commodity_id FK
        float quantity
        float capacity
    }
    
    TELEMETRY {
        string node_id FK
        string metric
        datetime timestamp
        float value
    }
    
    TAGS {
        string entity_type
        string entity_id FK
        string key
        string value
    }

    NODES ||--o{ COORDINATES : "has location"
    NODES ||--o{ NODE_ATTRIBUTE : "has attributes"
    NODES ||--o{ DEMANDS : "has demand"
    NODES ||--o{ INVENTORY : "stores"
    NODES ||--o{ TELEMETRY : "reports"
    
    NODES ||--o{ FLOWS : "source"
    NODES ||--o{ FLOWS : "target"
    NODES ||--o{ EDGE_ATTRIBUTE : "source"
    NODES ||--o{ EDGE_ATTRIBUTE : "target"
    
    COMMODITIES ||--o{ NODE_ATTRIBUTE : "dimension"
    COMMODITIES ||--o{ EDGE_ATTRIBUTE : "dimension"
    COMMODITIES ||--o{ FLOWS : "what flows"
    COMMODITIES ||--o{ DEMANDS : "what is needed"
    COMMODITIES ||--o{ INVENTORY : "what is stored"
    
    RESOURCES ||--o{ EDGE_ATTRIBUTE : "dimension"
    
    NODES ||--o{ TAGS : "tagged"
    RESOURCES ||--o{ TAGS : "tagged"
    COMMODITIES ||--o{ TAGS : "tagged"
```
