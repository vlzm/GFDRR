```mermaid
---
title: Class Diagram
---

classDiagram
    class GraphData {
        +DataFrame nodes
        +DataFrame resources
        +DataFrame commodities
        +DataFrame coordinates
        +dict~str,AttributeTable~ node_attributes
        +dict~str,AttributeTable~ edge_attributes
        +dict~str,FlowsTable~ flows
        +DataFrame demands
        +DataFrame inventory
        +DataFrame telemetry
        +DataFrame tags
        +add_node_attribute(attr)
        +add_edge_attribute(attr)
        +add_flows(flows)
    }

    class AttributeTable {
        +str name
        +str entity_type
        +str attribute_class
        +list~str~ granularity_keys
        +list~str~ value_columns
        +dict~str,ValueType~ value_types
        +DataFrame data
        +str description
        +dimension_keys() list~str~
    }

    class FlowsTable {
        +str name
        +list~str~ granularity_keys
        +str value_column
        +str value_type
        +DataFrame data
        +str description
        +dimension_keys() list~str~
    }

    class GraphQueryMixin {
        +get_nodes(node_type) DataFrame
        +get_node_attr(name, **filters) DataFrame
        +get_edge_attr(name, **filters) DataFrame
        +nodes_with_attrs(*attrs, **filters) DataFrame
        +edges_with_attrs(*attrs, **filters) DataFrame
        +get_flows(name, **filters) DataFrame
        +aggregate_flows(name, group_by) DataFrame
        +get_tag(entity_type, id, key) str
        +nodes_with_coordinates() DataFrame
        +info() str
        +describe_attr(name) str
    }

    class GraphDataWithQueries {
        <<combined>>
    }

    class DistanceService {
        +DataFrame coordinates
        +str backend
        +float default_speed_kmh
        +get_distance(src, tgt) float
        +get_duration(src, tgt) float
        +get_matrix(sources, targets) DataFrame
        +get_matrix_numpy(node_ids) ndarray
    }

    class EdgeBuilder {
        +GraphData graph
        +DistanceService distance_service
        +build(src_types, tgt_types) DataFrame
        +build_with_attrs(*attrs, **filters) DataFrame
        +build_complete_graph(node_ids) DataFrame
        +build_from_flows(flow_name) DataFrame
    }

    class GraphValidator {
        +validate(graph) ValidationResult
        +add_business_rule(rule)
    }

    class ValidationResult {
        +list~ValidationError~ errors
        +is_valid() bool
        +has_warnings() bool
        +raise_if_invalid()
    }

    GraphData "1" *-- "*" AttributeTable : node_attributes
    GraphData "1" *-- "*" AttributeTable : edge_attributes
    GraphData "1" *-- "*" FlowsTable : flows
    
    GraphDataWithQueries --|> GraphQueryMixin
    GraphDataWithQueries --|> GraphData
    
    EdgeBuilder --> GraphData : uses
    EdgeBuilder --> DistanceService : uses
    
    GraphValidator --> GraphData : validates
    GraphValidator --> ValidationResult : returns
```
