```mermaid
---
title: Attribute Granularity Examples
---

flowchart TB
    subgraph Concept["Granularity Concept"]
        direction LR
        G1["Simple<br/>node_id only"]
        G2["Medium<br/>node_id + commodity"]
        G3["Complex<br/>node_id + commodity + period + resource"]
    end

    subgraph FixedCost["fixed_cost (Simple)"]
        FC_Keys["granularity_keys:<br/>[node_id]"]
        FC_Data["
            | node_id | value |
            |---------|-------|
            | depot_1 | 5000  |
            | depot_2 | 6000  |
        "]
        FC_Join["JOIN ON: nodes.id = fixed_cost.node_id"]
    end

    subgraph VariableCost["variable_cost (Medium)"]
        VC_Keys["granularity_keys:<br/>[node_id, commodity_id]"]
        VC_Data["
            | node_id | commodity_id | value |
            |---------|--------------|-------|
            | depot_1 | bulk         | 10.0  |
            | depot_1 | cylinder     | 15.0  |
            | depot_2 | bulk         | 9.5   |
        "]
        VC_Join["JOIN ON: nodes.id = node_id<br/>AND filter commodity_id"]
    end

    subgraph TransportRate["transport_rate (Complex)"]
        TR_Keys["granularity_keys:<br/>[source_id, target_id,<br/>commodity_id, resource_id]"]
        TR_Data["
            | source | target | commodity | resource | value |
            |--------|--------|-----------|----------|-------|
            | depot_1| zone_1 | bulk      | tanker   | 15.0  |
            | depot_1| zone_1 | cylinder  | truck_lg | 18.0  |
        "]
        TR_Join["JOIN ON: edges.source_id, edges.target_id<br/>AND filter commodity, resource"]
    end

    subgraph Usage["Query Usage"]
        U1["graph.nodes_with_attrs('fixed_cost')"]
        U2["graph.nodes_with_attrs('variable_cost',<br/>commodity_id='bulk')"]
        U3["graph.edges_with_attrs('transport_rate',<br/>commodity_id='bulk',<br/>resource_id='tanker')"]
    end

    G1 --> FixedCost
    G2 --> VariableCost
    G3 --> TransportRate

    FixedCost --> U1
    VariableCost --> U2
    TransportRate --> U3

    style Concept fill:#f5f5f5,stroke:#9e9e9e
    style FixedCost fill:#e3f2fd,stroke:#1976d2
    style VariableCost fill:#fff3e0,stroke:#f57c00
    style TransportRate fill:#fce4ec,stroke:#c2185b
    style Usage fill:#e8f5e9,stroke:#388e3c
```
