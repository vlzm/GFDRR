```mermaid
---
title: Module Dependencies
---

flowchart TB
    subgraph Package["graph_model package"]
        direction TB
        
        subgraph Core["core.py"]
            GraphData
            AttributeTable
            FlowsTable
        end
        
        subgraph Queries["queries.py"]
            GraphQueryMixin
            GraphDataWithQueries
        end
        
        subgraph Builders["builders.py"]
            DistanceService
            EdgeBuilder
        end
        
        subgraph Validators["validators.py"]
            GraphValidator
            ValidationResult
            validate_graph
        end
        
        subgraph IO["io.py"]
            save_parquet
            load_parquet
            save_json
            load_json
            to_dict
            from_dict
        end
        
        Init["__init__.py<br/>(exports all)"]
    end

    subgraph External["External Dependencies"]
        Pandas["pandas"]
        NumPy["numpy"]
        Math["math (stdlib)"]
        JSON["json (stdlib)"]
        Pathlib["pathlib (stdlib)"]
    end

    %% Internal dependencies
    Queries --> Core
    Builders --> Core
    Validators --> Core
    IO --> Core
    
    GraphDataWithQueries --> GraphData
    GraphDataWithQueries --> GraphQueryMixin
    
    EdgeBuilder --> DistanceService
    
    Init --> Core
    Init --> Queries
    Init --> Builders
    Init --> Validators
    Init --> IO

    %% External dependencies
    Core --> Pandas
    Queries --> Pandas
    Builders --> Pandas
    Builders --> NumPy
    Builders --> Math
    Validators --> Pandas
    IO --> Pandas
    IO --> JSON
    IO --> Pathlib

    style Core fill:#e3f2fd,stroke:#1565c0
    style Queries fill:#e8f5e9,stroke:#2e7d32
    style Builders fill:#fff3e0,stroke:#ef6c00
    style Validators fill:#fce4ec,stroke:#c2185b
    style IO fill:#f3e5f5,stroke:#7b1fa2
    style Init fill:#eceff1,stroke:#607d8b
```
