---
title: "14. Environment Phases — Per-Period Execution Detail"
---

flowchart TB
    STATE_IN(["SimulationState<br/>───────────<br/>inventory · in_transit · resources<br/>(immutable, frozen=True)"])

    STATE_IN --> DEM_START

    %% ═══════════════════════════════════════════
    %% DEMAND PHASE
    %% ═══════════════════════════════════════════

    subgraph DemandPhase["DemandPhase"]
        direction TB
        DEM_START["Filter resolved.demand<br/>where period_id = current"]
        DEM_MERGE["Merge demand with inventory<br/>on (facility_id, commodity_category)"]
        DEM_CALC["fulfilled = min(demand, available)<br/>deficit = demand − fulfilled<br/>───────────<br/>vectorized: np.minimum()"]
        DEM_UPD["inventory.quantity -= fulfilled"]
        DEM_OUT_F["flow_events<br/>───────────<br/>source='EXT' → facility<br/>commodity, fulfilled qty"]
        DEM_OUT_U["unmet_demand<br/>───────────<br/>facility, commodity,<br/>requested, fulfilled, deficit"]

        DEM_START --> DEM_MERGE --> DEM_CALC
        DEM_CALC --> DEM_UPD
        DEM_CALC -->|"deficit > 0"| DEM_OUT_U
        DEM_CALC -->|"fulfilled > 0"| DEM_OUT_F
    end

    DEM_UPD --> ARR_START

    %% ═══════════════════════════════════════════
    %% ARRIVALS PHASE
    %% ═══════════════════════════════════════════

    subgraph ArrivalsPhase["ArrivalsPhase"]
        direction TB
        ARR_START["Filter in_transit<br/>where arrival_period = period_index"]
        ARR_SPLIT["Split: arriving / remaining"]
        ARR_INV["Group arriving by (target, commodity)<br/>Add quantities to inventory<br/>───────────<br/>merge + sum"]
        ARR_RES["Update arriving resources:<br/>status: IN_TRANSIT → AVAILABLE<br/>current_facility_id ← target<br/>available_at_period ← NaN<br/>───────────<br/>set_index().map() pattern"]
        ARR_TRANSIT["in_transit ← remaining only"]
        ARR_OUT_F["flow_events<br/>───────────<br/>source → target<br/>commodity, arrived qty"]

        ARR_START --> ARR_SPLIT
        ARR_SPLIT --> ARR_INV
        ARR_SPLIT --> ARR_RES
        ARR_SPLIT --> ARR_TRANSIT
        ARR_INV --> ARR_OUT_F
    end

    ARR_INV --> DISP_START
    ARR_RES --> DISP_START
    ARR_TRANSIT --> DISP_START

    %% ═══════════════════════════════════════════
    %% DISPATCH PHASE
    %% ═══════════════════════════════════════════

    subgraph DispatchPhase["DispatchPhase(Task)"]
        direction TB

        DISP_START["Task.run(state, resolved, period)<br/>───────────<br/>Domain-specific decision:<br/>returns dispatches DataFrame<br/>(source, target, commodity, qty,<br/>resource_id?, modal_type?, arrival)"]

        subgraph AutoAssign["Auto-Assign Resources"]
            AA_FILTER["For each dispatch with resource_id = null:<br/>find available resources at source_id"]
            AA_COMPAT["Apply compatibility filters:<br/>• resource ↔ commodity<br/>• resource ↔ modal_type"]
            AA_PICK["Pick first candidate,<br/>remove from pool<br/>───────────<br/>sequential, greedy"]
            AA_FILTER --> AA_COMPAT --> AA_PICK
        end

        subgraph Validate["Validate Dispatches (5 checks)"]
            V1["① Arrival period ≥ current?"]
            V2["② Edge (source, target, modal) exists?"]
            V3["③ Resource AVAILABLE at source?"]
            V4["④ Resource capacity ≥ total qty?<br/>───────────<br/>groupby resource_id,<br/>sum qty ≤ base_capacity"]
            V5["⑤ Source inventory ≥ total dispatched?<br/>───────────<br/>aggregated per (source, commodity)"]
            V_SPLIT{"pass / fail?"}

            V1 --> V2 --> V3 --> V4 --> V5 --> V_SPLIT
        end

        V_SPLIT -->|"rejected"| DISP_REJ
        V_SPLIT -->|"valid"| APPLY

        DISP_REJ["rejected_dispatches<br/>───────────<br/>+ reason:<br/>INVALID_ARRIVAL<br/>INVALID_EDGE<br/>NO_AVAILABLE_RESOURCE<br/>OVER_CAPACITY<br/>INSUFFICIENT_INVENTORY"]

        subgraph APPLY["Apply Valid Dispatches"]
            AP_ID["Generate shipment_id<br/>shp_{period}_{i}"]
            AP_INV["Decrement source inventory<br/>───────────<br/>groupby (source, commodity),<br/>merge + subtract"]
            AP_TRANSIT["Append to in_transit<br/>───────────<br/>shipment_id, source, target,<br/>commodity, qty, resource,<br/>departure, arrival"]
            AP_RES["Update resources:<br/>status ← IN_TRANSIT<br/>current_facility_id ← target<br/>available_at_period ← arrival"]
            AP_FLOW["flow_events<br/>───────────<br/>source → target<br/>commodity, modal, qty, resource"]

            AP_ID --> AP_INV
            AP_ID --> AP_TRANSIT
            AP_ID --> AP_RES
            AP_INV --> AP_FLOW
        end

        DISP_START --> AutoAssign --> Validate
    end

    %% ═══════════════════════════════════════════
    %% OUTPUTS
    %% ═══════════════════════════════════════════

    subgraph PhaseResult["PhaseResult (per phase)"]
        PR_S["state: SimulationState (updated)"]
        PR_F["flow_events: DataFrame"]
        PR_U["unmet_demand: DataFrame"]
        PR_R["rejected_dispatches: DataFrame"]
    end

    AP_FLOW --> PR_F
    AP_INV --> PR_S
    DISP_REJ --> PR_R
    DEM_OUT_F --> PR_F
    DEM_OUT_U --> PR_U
    ARR_OUT_F --> PR_F

    subgraph LogRecord["SimulationLog.record_*()"]
        LR_SNAP["record_period(state, period)<br/>→ snapshot inventory + resources"]
        LR_EVT["record_events(result, phase, period)<br/>→ append flow, unmet, rejected"]
    end

    PR_S --> LR_SNAP
    PR_F --> LR_EVT
    PR_U --> LR_EVT
    PR_R --> LR_EVT

    STATE_OUT(["SimulationState (end of period)<br/>───────────<br/>inventory: updated<br/>in_transit: updated<br/>resources: updated<br/>→ advance_period() → next period"])

    LR_SNAP --> STATE_OUT

    classDef state fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef demand fill:#e3f2fd,stroke:#1565c0
    classDef arrivals fill:#e8f5e9,stroke:#2e7d32
    classDef dispatch fill:#f3e5f5,stroke:#7b1fa2
    classDef validate fill:#fff9c4,stroke:#f57f17
    classDef apply fill:#e8eaf6,stroke:#283593
    classDef reject fill:#ffcdd2,stroke:#c62828
    classDef result fill:#f5f5f5,stroke:#616161,stroke-width:2px
    classDef log fill:#e0f2f1,stroke:#00695c

    class STATE_IN,STATE_OUT state
    class DemandPhase demand
    class ArrivalsPhase arrivals
    class DispatchPhase dispatch
    class Validate validate
    class APPLY,AutoAssign apply
    class DISP_REJ reject
    class PhaseResult result
    class LogRecord log
