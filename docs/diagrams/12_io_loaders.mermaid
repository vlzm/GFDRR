---
title: "12. I/O & Loaders — Data Flow In and Out"
---

flowchart TB
    subgraph DataSources["Data Sources"]
        CSV["CSV / DB / API"]
        Mock["DataLoaderMock<br/>───────────<br/>Synthetic Citi Bike data:<br/>stations, depots, resources,<br/>trips, costs"]
        Custom["Custom DataSourceProtocol<br/>───────────<br/>df_stations, df_depots,<br/>df_resources, timestamps,<br/>df_inventory_ts, df_trips, etc."]
    end

    subgraph Loaders["gbp.loaders"]
        DSP["DataSourceProtocol<br/>───────────<br/>load_data() → populates DataFrames"]
        GLC["GraphLoaderConfig<br/>───────────<br/>distance_backend: haversine|euclidean<br/>default_speed_kmh: 50.0<br/>build_edges: true"]
        DLG["DataLoaderGraph<br/>───────────<br/>load_data():<br/>Pandera validate source<br/>→ assemble RawModelData<br/>→ build_model() → ResolvedModelData"]
        GLP["GraphLoaderProtocol<br/>───────────<br/>raw, resolved, source<br/>available_dates<br/>rebalancer_snapshot(date)"]
    end

    subgraph CoreModel["gbp.core"]
        RMD["RawModelData<br/>───────────<br/>~30 DataFrames<br/>with raw dates"]
        ResMD["ResolvedModelData<br/>───────────<br/>Resolved tables + spines"]
        Build["build_model(raw)<br/>───────────<br/>Validation → Resolution →<br/>Edge Building → Spine Assembly"]
        RMD -->|"build_model()"| Build --> ResMD
    end

    subgraph IO["gbp.io — Serialization"]
        direction TB
        
        subgraph Parquet["Parquet Format"]
            SaveRawPQ["save_raw_parquet(raw, dir)"]
            LoadRawPQ["load_raw_parquet(dir)"]
            SaveResPQ["save_resolved_parquet(resolved, dir)"]
            LoadResPQ["load_resolved_parquet(dir)"]
            PQLayout["Directory layout:<br/>dir/<br/>├── _metadata.json<br/>├── facilities.parquet<br/>├── edges.parquet<br/>├── facility_spines/<br/>│   ├── group_0.parquet<br/>│   └── ...<br/>└── ..."]
        end

        subgraph DictJSON["Dict / JSON Format"]
            RawToDict["raw_to_dict(raw) → dict"]
            RawFromDict["raw_from_dict(dict) → RawModelData"]
            ResToDict["resolved_to_dict(resolved) → dict"]
            ResFromDict["resolved_from_dict(dict) → ResolvedModelData"]
        end
    end

    subgraph Consumers["Consumers"]
        Optimizer["Optimizer"]
        Simulator["Simulator"]
        Analytics["Analytics"]
    end

    CSV --> DSP
    Mock --> DSP
    Custom --> DSP
    DSP --> DLG
    GLC --> DLG
    DLG --> GLP

    RMD --> SaveRawPQ
    LoadRawPQ --> RMD
    ResMD --> SaveResPQ
    LoadResPQ --> ResMD

    RMD --> RawToDict
    RawFromDict --> RMD
    ResMD --> ResToDict
    ResFromDict --> ResMD

    ResMD --> Consumers

    classDef sources fill:#ffcdd2,stroke:#c62828
    classDef loaders fill:#fff3e0,stroke:#e65100
    classDef core fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef io fill:#e8f5e9,stroke:#2e7d32
    classDef consumers fill:#f3e5f5,stroke:#7b1fa2

    class DataSources sources
    class Loaders loaders
    class CoreModel core
    class IO io
    class Consumers consumers
